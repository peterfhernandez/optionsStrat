# Deribit API credentials
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.
#
# Paper trading keys  →  register at https://test.deribit.com
#                         Account → API → Add Key
DERIBIT_PAPER_CLIENT_ID=
DERIBIT_PAPER_CLIENT_SECRET=
#
# Live trading keys   →  register at https://www.deribit.com
#                         Account → API → Add Key
DERIBIT_LIVE_CLIENT_ID=
DERIBIT_LIVE_CLIENT_SECRET=
